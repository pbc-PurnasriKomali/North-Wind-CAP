{
  "name": "northwind-cap",
  "version": "1.0.0",
  "description": "SAP CAP Node.js facade over the public Northwind OData v4 service",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "cds-serve",
    "watch": "cds watch",
    "build": "mbt build"
  },
  "dependencies": {
    "@sap-cloud-sdk/http-client": "^4.7.0",
    "@sap-cloud-sdk/resilience": "^4.7.0",
    "@sap/cds": "^8",
    "express": "^4"
  },
  "devDependencies": {
    "@cap-js/sqlite": "^1",
    "@sap/cds-dk": "^8"
  },
  "cds": {
    "requires": {
      "Northwind": {
        "kind": "odata-v4",
        "model": "srv/external/Northwind",
        "credentials": {
          "url": "https://services.odata.org/V4/Northwind/Northwind.svc"
        },
        "options": {
          "requestTimeout": 5000
        }
      },
      "[production]": {
        "auth": {
          "kind": "xsuaa"
        }
      },
      "[development]": {
        "auth": {
          "kind": "dummy"
        }
      }
    },
    "features": {
      "assert_integrity": false
    },
    "server": {
      "port": 4004
    }
  }
}
